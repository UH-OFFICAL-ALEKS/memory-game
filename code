import tkinter as tk
import random

# ==================== НАСТРОЙКИ СТИЛЯ ====================
ORANGE_BG = "#FFB347"      # мягкий тёплый оранжевый

# ШРИФТЫ (можно менять на любые)
FONT_TITLE = ("Comic Sans MS", 20, "bold")      # для заголовков
FONT_BUTTON = ("Verdana", 12, "bold")           # для кнопок
FONT_QUESTION = ("Arial", 14, "bold")           # для вопросов
FONT_RESULT = ("Segoe UI", 28, "bold")          # для процента результата
FONT_ANSWER = ("Courier New", 12)               # для списка правильных ответов
FONT_MENU = ("Georgia", 14, "bold")             # для текста в меню

# ==================== ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ====================
target_shapes = []  # [(shape_ru, color_ru, color_orig), ...]
user_answers = []
current_step = 0

# Словарь для перевода цветов
translate_colors = {
    "red": "красный", "blue": "синий", "yellow": "желтый", "purple": "фиолетовый",
    "#ff0000": "красный", "#0000ff": "синий", "#ffff00": "желтый", "#800080": "фиолетовый"
}

def color_to_russian(color):
    """Переводит английское название цвета или HEX-код в русское название"""
    key = color.lower()
    return translate_colors.get(key, key)

def start_game(count, seconds, colors):
    """Запускает игру: создаёт окно с фигурами"""
    for widget in root.winfo_children():
        widget.destroy()

    global target_shapes, current_step, user_answers
    target_shapes = []
    user_answers = []
    current_step = 0

    # Холст с оранжевым фоном
    canvas = tk.Canvas(root, width=400, height=400, bg=ORANGE_BG, highlightthickness=0)
    canvas.pack()

    shapes_list = ["квадрат", "круг", "треугольник"]

    occupied = []
    def overlaps(x1, y1, x2, y2):
        """Проверяет, пересекается ли новая фигура с уже существующими"""
        for ox1, oy1, ox2, oy2 in occupied:
            if not (x2 < ox1 or x1 > ox2 or y2 < oy1 or y1 > oy2):
                return True
        return False

    for i in range(count):
        shape = random.choice(shapes_list)
        color = random.choice(colors)
        color_ru = color_to_russian(color)
        target_shapes.append((shape, color_ru, color))

        for _ in range(100):
            x = random.randint(20, 320)
            y = random.randint(20, 320)
            x2, y2 = x + 60, y + 60
            if not overlaps(x, y, x2, y2):
                occupied.append((x, y, x2, y2))
                break
        else:
            x, y = random.randint(20, 320), random.randint(20, 320)

        if shape == "квадрат":
            canvas.create_rectangle(x, y, x + 60, y + 60, fill=color, outline="")
        elif shape == "круг":
            canvas.create_oval(x, y, x + 60, y + 60, fill=color, outline="")
        elif shape == "треугольник":
            canvas.create_polygon(x, y + 60, x + 30, y, x + 60, y + 60, fill=color, outline="")

    root.after(int(seconds * 1000), lambda: ask_user(canvas))

def ask_user(canvas):
    """Удаляет холст с фигурами и показывает интерфейс для ввода ответов"""
    canvas.destroy()
    root.config(bg=ORANGE_BG)

    global label_ask, entry_answer, btn_next
    label_ask = tk.Label(root, text=f"Какая была 1-я фигура и её цвет?\n(Напр.: квадрат красный)", 
                         bg=ORANGE_BG, fg="white", font=FONT_QUESTION)
    label_ask.pack(pady=20)

    entry_answer = tk.Entry(root, width=30, font=FONT_BUTTON)
    entry_answer.pack(pady=10)

    btn_next = tk.Button(root, text="Ответить", font=FONT_BUTTON, command=check_answer,
                         bd=0, highlightthickness=0)
    btn_next.pack(pady=10)

def check_answer():
    """Проверяет ответ пользователя и переходит к следующему вопросу"""
    global current_step
    ans = entry_answer.get().lower().strip()
    user_answers.append(ans)
    entry_answer.delete(0, tk.END)

    current_step += 1
    if current_step < len(target_shapes):
        label_ask.config(text=f"Какая была {current_step+1}-я фигура и её цвет?")
    else:
        show_result()

def show_result():
    """Показывает результат игры: процент правильных ответов и список правильных фигур"""
    for widget in root.winfo_children():
        widget.destroy()

    correct_points = 0
    total_elements = len(target_shapes) * 2

    for i, (true_shape, true_color_ru, true_color_orig) in enumerate(target_shapes):
        user_ans = user_answers[i] if i < len(user_answers) else ""
        if true_shape in user_ans:
            correct_points += 1
        color_ok = False
        if true_color_ru in user_ans:
            color_ok = True
        else:
            if isinstance(true_color_orig, str) and true_color_orig.lower() in user_ans:
                color_ok = True
            elif true_color_ru[:-1] in user_ans:
                color_ok = True
        if color_ok:
            correct_points += 1

    percent = int((correct_points / total_elements) * 100) if total_elements > 0 else 0

    tk.Label(root, text=f"Результат: {percent}%", bg=ORANGE_BG, fg="white", font=FONT_RESULT).pack(pady=20)

    answers_frame = tk.Frame(root, bg=ORANGE_BG)
    answers_frame.pack(pady=10)
    for i, (shape, color_ru, color_orig) in enumerate(target_shapes, start=1):
        tk.Label(answers_frame, text=f"{i}: {shape}, {color_ru} ({color_orig})",
                 bg=ORANGE_BG, fg="white", font=FONT_ANSWER).pack()

    tk.Button(root, text="В меню", font=FONT_BUTTON, command=main_menu,
              bd=0, highlightthickness=0).pack(pady=15)


def main_menu():
    """Главное меню игры"""
    for widget in root.winfo_children():
        widget.destroy()
    root.config(bg=ORANGE_BG)

    frame = tk.Frame(root, bg=ORANGE_BG)
    frame.pack(expand=True)

    title = tk.Label(frame, text="🧠 MEMORY GAME", bg=ORANGE_BG, fg="white", font=FONT_TITLE)
    title.pack(pady=30)

    # Кнопка без чёрной обводки
    start_button = tk.Button(frame, text="Старт", bg="white", font=FONT_MENU, command=difficulty_screen,
                             bd=0, highlightthickness=0, activebackground="white")
    start_button.pack(pady=20)


def difficulty_screen():
    """Экран выбора уровня сложности"""
    for widget in root.winfo_children():
        widget.destroy()
    root.config(bg=ORANGE_BG)

    frame = tk.Frame(root, bg=ORANGE_BG)
    frame.pack(expand=True, pady=20)

    c_std = ["red", "blue", "yellow"]
    c_hard = ["red", "blue", "yellow", "purple"]

    tk.Label(frame, text="Выберите сложность:", bg=ORANGE_BG, fg="white", font=FONT_QUESTION).pack(pady=5)

    tk.Button(frame, text="Простой (2 фиг, 10 сек)", bg="green", fg="white", width=25, font=FONT_BUTTON,
              command=lambda: start_game(2, 10, c_std), bd=0, highlightthickness=0).pack(pady=6)

    tk.Button(frame, text="Средний (3 фиг, 8 сек)", bg="yellow", fg="black", width=25, font=FONT_BUTTON,
              command=lambda: start_game(3, 8, c_std), bd=0, highlightthickness=0).pack(pady=6)

    tk.Button(frame, text="Сложный (4 фиг, 6 сек)", bg="red", fg="white", width=25, font=FONT_BUTTON,
              command=lambda: start_game(4, 6, c_hard), bd=0, highlightthickness=0).pack(pady=6)


# ==================== ЗАПУСК ====================
root = tk.Tk()
root.title("Memory Game")
root.geometry("400x450")
root.resizable(False, False)
main_menu()
root.mainloop()
